    "Instruction5:Alignment" [label="StartToStart", shape=box];
    "Instruction5:Relationship" [label="InstructionRelationship", shape=box];
    "Instruction5:Relationship" -> "Instruction5:Alignment"  [label="Alignment", style=dashed];
    "Instruction5" [label="Dependency", shape=box];
